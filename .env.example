VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# AI (шаг 1 — авто-разметка фото, шаг 4 — анализ конкурента).
# По умолчанию используется ZvenoAI (OpenAI-совместимый, оплата в рублях).
# ВНИМАНИЕ: переменные VITE_* попадают в клиентский бандл и видны всем.
# Для продакшена ключ держите на бэкенд-прокси. Без ключа шаги работают вручную.
VITE_AI_API_KEY=sk-...
VITE_AI_BASE_URL=https://api.zveno.ai/v1
VITE_AI_MODEL=google/gemini-2.5-flash-lite
